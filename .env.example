# Copy this file to .env and fill in real values.
# .env is gitignored -- never commit real keys.

ENVIRONMENT=local
LOG_LEVEL=INFO

# Free tier: https://finnhub.io/register
FINNHUB_API_KEY=

# Free tier (25 req/day), fallback source only: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Free tier (100 req/day): https://www.marketaux.com/account/dashboard
MARKETAUX_API_KEY=

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=marketpulse
DATABASE_USER=marketpulse
DATABASE_PASSWORD=
